# ─────────────────────────────────────────────────────
# .gitignore
# Tells Git which files to NEVER upload to GitHub.
# ─────────────────────────────────────────────────────

# Python cache files (auto-generated, not needed)
__pycache__/
*.pyc
*.pyo

# Jupyter notebook checkpoints (auto-saved drafts)
.ipynb_checkpoints/

# Environment files (contain secrets)
.env
venv/
.venv/

# Anaconda specific
.conda/
*.egg-info/
dist/
build/

# OS generated files
.DS_Store
Thumbs.db

# Processed data (regenerated by running the code)
data/processed/*.csv